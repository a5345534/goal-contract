{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-contract/schemas/source-manifest.schema.json",
  "title": "OpenSpec Source Manifest",
  "description": "Canonical shape of source-manifest.json produced by goal-spec and consumed by goal-dag.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "changeName", "generatedAt", "sources"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "changeName": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "anyOf": [
              { "pattern": "^/" },
              { "pattern": "(^|/)\\.\\.(/|$)" }
            ]
          }
        },
        "kind": {
          "enum": ["proposal", "design", "tasks", "spec-delta"]
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
