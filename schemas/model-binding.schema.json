{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-contract/schemas/model-binding.schema.json",
  "title": "Goal Model Binding Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "harness", "bindings"],
  "properties": {
    "version": { "enum": [1, 2] },
    "harness": { "type": "string", "minLength": 1 },
    "bindings": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[-_.][a-z0-9]+)*$" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "version": { "const": 1 } }, "required": ["version"] },
      "then": {
        "properties": {
          "bindings": { "additionalProperties": { "$ref": "#/$defs/legacyBinding" } }
        }
      }
    },
    {
      "if": { "properties": { "version": { "const": 2 } }, "required": ["version"] },
      "then": {
        "properties": {
          "bindings": { "additionalProperties": { "$ref": "#/$defs/binding" } }
        }
      }
    }
  ],
  "$defs": {
    "capabilityLevel": { "enum": ["none", "low", "medium", "high", "very_high"] },
    "minimumRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reasoning": { "$ref": "#/$defs/capabilityLevel" },
        "contextWindowTokens": { "type": "integer", "minimum": 1 },
        "toolUse": { "enum": ["none", "optional", "required"] },
        "structuredOutput": { "enum": ["none", "preferred", "strict"] },
        "formatFollowing": { "$ref": "#/$defs/capabilityLevel" },
        "sourceCitation": { "enum": ["none", "preferred", "required"] },
        "costSensitivity": { "enum": ["low", "medium", "high"] },
        "privacy": { "enum": ["cloud-ok", "local-only"] }
      }
    },
    "binding": {
      "oneOf": [
        { "$ref": "#/$defs/legacyBinding" },
        { "$ref": "#/$defs/candidateChainBinding" }
      ]
    },
    "legacyBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "declaredCapabilities"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "declaredCapabilities": { "$ref": "#/$defs/minimumRequirements" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "candidateChainBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates"],
      "properties": {
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/candidate" }
        },
        "retryPolicy": { "$ref": "#/$defs/retryPolicy" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "declaredCapabilities"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "declaredCapabilities": { "$ref": "#/$defs/minimumRequirements" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attemptsPerCandidate"],
      "properties": {
        "attemptsPerCandidate": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
