{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-contract/schemas/model-routing.schema.json",
  "title": "Goal Model Routing Config",
  "description": "Abstract modelClass routing shared by goal-dag and goal-runner. Concrete provider/model ids are only allowed in harness binding catalogs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenarios"],
  "properties": {
    "scenarios": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/scenarioId" },
      "additionalProperties": {
        "type": "object",
        "required": ["modelClass"],
        "additionalProperties": false,
        "properties": {
          "modelClass": { "$ref": "#/$defs/modelClassId" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "controllerScenario": { "$ref": "#/$defs/scenarioId" },
    "defaultSubagentScenario": { "$ref": "#/$defs/scenarioId" },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/routingRule" }
    }
  },
  "$defs": {
    "scenarioId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[-_.][a-z0-9]+)*$"
    },
    "modelClassId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[-_.][a-z0-9]+)*$"
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "routingRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario"],
      "properties": {
        "scenario": { "$ref": "#/$defs/scenarioId" },
        "when": { "$ref": "#/$defs/routingRuleMatch" }
      }
    },
    "routingRuleMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodeIds": { "$ref": "#/$defs/stringList" },
        "scopes": { "$ref": "#/$defs/stringList" },
        "risks": {
          "type": "array",
          "items": { "enum": ["low", "medium", "high"] }
        },
        "modules": { "$ref": "#/$defs/stringList" },
        "capabilities": { "$ref": "#/$defs/stringList" },
        "files": { "$ref": "#/$defs/stringList" },
        "objectiveIncludes": { "$ref": "#/$defs/stringList" },
        "hasValidators": { "type": "boolean" },
        "hasOutputs": { "type": "boolean" }
      }
    }
  }
}
