{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-contract/schemas/model-routing.schema.json",
  "title": "Goal Model Routing Config",
  "description": "Canonical model-routing configuration shared by goal-dag and goal-runner.",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenarios"],
  "properties": {
    "scenarios": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["model"],
        "additionalProperties": false,
        "properties": {
          "model": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:[-_.][a-z][a-z0-9]*)*\\/[a-z][a-z0-9]*(?:[-_.][a-z0-9]+)*$"
          },
          "description": { "type": "string" }
        }
      }
    },
    "controllerScenario": { "type": "string", "minLength": 1 },
    "defaultSubagentScenario": { "type": "string", "minLength": 1 },
    "rules": { "type": "array" }
  }
}
